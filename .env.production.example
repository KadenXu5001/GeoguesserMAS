# Copy to a root-owned file outside the checkout and restrict it to mode 0600.
APP_DOMAIN=geo-trainer.com

# Use long URL-safe values so they can be embedded in MongoDB URIs without percent encoding.
MONGO_ROOT_USERNAME=root
MONGO_ROOT_PASSWORD=replace_with_url_safe_root_password
MONGO_APP_USERNAME=geotrainer_app
MONGO_APP_PASSWORD=replace_with_url_safe_app_password
MONGODB_DATABASE=geoguesser

GEOTRAINER_MEDIA_DIR=/srv/geotrainer/media
GEOTRAINER_MEDIA_BUCKET=gs://worldwide_images_geotrainer
GEOTRAINER_MEDIA_GID=2000
GEMINI_API_KEY=replace_me
GEMINI_REFERENCE_MODEL=gemini-3.5-flash
LANGSMITH_API_KEY=replace_me
LANGSMITH_ENDPOINT=https://api.smith.langchain.com
LANGSMITH_PROJECT=geoguesser

MAS_USER_REQUESTS_PER_HOUR=6
MAS_IP_REQUESTS_PER_HOUR=12
MONTHLY_MAS_BUDGET_USD=3.00
ACTIVE_ROUND_TTL_HOURS=24
